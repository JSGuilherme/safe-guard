# Configuração da API CofreSenhaRust
# Copie este arquivo para .env e ajuste os valores conforme necessário

# Porta em que a API local escuta
# Padrão: 5474
API_PORT=5474

# Timeout de inatividade da sessão em segundos
# Padrão: 7200 (2 horas)
# Quando uma sessão fica inativa por esse período, ela expira
SESSION_TTL_SECS=7200

# Vida máxima absoluta da sessão em segundos
# Padrão: 43200 (12 horas)
# Mesmo que a sessão seja renovada continuamente, ela expira após esse período
SESSION_MAX_TTL_SECS=43200
